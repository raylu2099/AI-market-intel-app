# === market-intel configuration ===
# Copy to .env and fill in real values. .env is gitignored.

# --- Required secrets ---
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=000000000

# --- Claude runner ---
# "cli" = use `claude -p` (Claude Max/Pro subscription, no extra billing)
# "api" = use Anthropic API directly (requires ANTHROPIC_API_KEY)
CLAUDE_RUNNER=cli
CLAUDE_MODEL=claude-sonnet-4-6
# Only for api runner:
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Optional: Financial Datasets API (better earnings/fundamentals data) ---
# FINANCIAL_DATASETS_API_KEY=your_key_here

# --- Optional: FRED API (macroeconomic data from Federal Reserve) ---
# FRED_API_KEY=your_key_here

# --- Paths (override if you want data outside the project dir) ---
# MARKET_INTEL_DATA_DIR=/var/lib/market-intel/data
# MARKET_INTEL_LOGS_DIR=/var/log/market-intel

# --- Watchlist (comma-separated TICKER:NAME pairs) ---
WATCHLIST=META:Meta,GOOGL:Google,NVDA:Nvidia,TSLA:Tesla,NVO:Novo Nordisk

# --- Timezone (Olson tz name; cron respects this for slot labels) ---
# US/Pacific for LA-based trader; the system also tracks Beijing time for China slots.
MARKET_TZ=US/Pacific

# --- Perplexity tuning ---
PPLX_MODEL_SEARCH=sonar
PPLX_MODEL_ANALYSIS=sonar-pro
PPLX_SEARCH_CONTEXT=high

# --- History window (days) used by the Claude analyst ---
HISTORY_WINDOW_DAYS=30
